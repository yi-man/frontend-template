# Environment Variables
# Copy this file to .env.local to set your local environment variables

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Next.js 16 SSR Template"
NEXT_PUBLIC_APP_DESCRIPTION="A modern, production-ready Next.js 16 SSR template"

# Analytics
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# Performance
NEXT_PUBLIC_ENABLE_MSW=false

# OpenAI 兼容 API（LangChain / 聊天演示；未配置时 /api/chat 返回离线提示流）
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# 示例：火山方舟（豆包）— 可与 hiring-agent 项目共用同一套变量：
# OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# OPENAI_MODEL=your-model-endpoint-name
