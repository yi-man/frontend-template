{
  "name": "nextjs16-ssr-template",
  "version": "0.1.0",
  "private": true,
  "description": "A modern Next.js 16 SSR template for content websites",
  "author": "Your Name <your.email@example.com>",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "bun --bun next dev --turbopack",
    "build": "bun --bun next build",
    "start": "bun --bun next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "test": "bun test --coverage --max-concurrency=1",
    "test:watch": "bun test --watch --max-concurrency=1",
    "test:ci": "bun test --coverage --max-concurrency=1",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "test:e2e": "start-server-and-test 'bun run dev' http://localhost:3000 'bun run cypress:run'",
    "prepare": "husky",
    "clean": "rm -rf .next node_modules coverage",
    "reinstall": "bun run clean && bun install"
  },
  "dependencies": {
